<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Shared container for app ⇄ keyboard settings/result sync. The group ID
	     comes from the APP_GROUP_ID build setting (change it in one place when
	     forking; group IDs are unique per developer team). -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>$(APP_GROUP_ID)</string>
	</array>
</dict>
</plist>
