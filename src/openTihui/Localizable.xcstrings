    "Context, reasoning, sampling and image size for new chats and the keyboard’s “Generate in app”. Shortcuts use their own settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于新对话和键盘“在应用中生成”的上下文长度、推理、采样和图片尺寸。快捷指令使用各自的设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用於新對話和鍵盤「在應用中生成」的上下文長度、推理、取樣和圖片尺寸。快捷指令使用各自的設定。"
          }
        }
      }
    },
