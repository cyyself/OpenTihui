      }
    },
    "Used for new chats that aren’t started from a shortcut. Context length, sampling and reasoning are tuned per-chat (Chat Settings) or in a Shortcut.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于非从快捷指令启动的新聊天。上下文长度、采样和推理可按聊天（聊天设置）或在快捷指令中调整。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用於非從快捷指令啟動的新聊天。上下文長度、取樣和推理可按聊天（聊天設定）或在快捷指令中調整。"
          }
        }
      }
    },
    "Using %@%@.": {
      "localizations": {
