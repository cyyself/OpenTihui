        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「自動」可讓回覆使用至完整的上下文視窗。"
          }
        }
      }
    },
    "%@:": {
      "comment": "A label with a variable name and an optional value. The first argument is the name of the variable. The second argument is the value of the variable, if it is not empty.",
      "isCommentAutoGenerated": true
    },
    "%lld": {
