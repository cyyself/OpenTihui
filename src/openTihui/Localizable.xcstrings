          }
        }
      }
    },
    "“Auto” lets a reply run up to the full context window.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“自动”可让回复使用至完整的上下文窗口。"
