            "value": "將使用者的訊息從 $from 翻譯成 $into。只輸出譯文，不要額外說明。"
          }
        }
      }
    },
    "Translator": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
