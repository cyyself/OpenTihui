            "state": "translated",
            "value": "試一試"
          }
        }
      }
    },
    "Try the recommended **Qwen3.5 0.8B** — a small, fast, vision-capable model that runs well on-device.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "试试推荐的 **Qwen3.5 0.8B** — 一个小巧、快速、支持视觉、在设备上运行良好的模型。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "試試推薦的 **Qwen3.5 0.8B** — 一個小巧、快速、支援視覺、在裝置上運行良好的模型。"
          }
        }
      }
    },
    "Turn off multimodal to save memory on text-only chats (skips loading the vision projector). Stateless answers each message with a fresh context — earlier turns stay in the transcript but aren't sent to the model, keeping the KV cache small (great for translation and other one-shot tasks).": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭多模态可在纯文本聊天中节省内存（跳过加载视觉投影器）。无状态模式以全新的上下文回答每条消息 — 之前的对话仍显示在记录中，但不会发送给模型，从而保持 KV 缓存较小（非常适合翻译等一次性任务）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉多模態可在純文字聊天中節省記憶體（跳過載入視覺投影器）。無狀態模式以全新的上下文回答每則訊息 — 之前的對話仍顯示在記錄中，但不會傳送給模型，從而保持 KV 快取較小（非常適合翻譯等一次性任務）。"
          }
        }
      }
    },
    "Type or edit the text…": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入或编辑文本…"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輸入或編輯文字…"
          }
        }
      }
    },
    "Use an on-device model or a remote API endpoint. On-device models reload when changed; API endpoints connect on send.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用设备端模型或远程 API 端点。设备端模型在更改时重新加载；API 端点在发送时连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用裝置端模型或遠端 API 端點。裝置端模型在變更時重新載入；API 端點在傳送時連線。"
          }
        }
      }
    },
    "Use selected lines": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用所选行"
          }
        },
