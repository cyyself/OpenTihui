    "Choose which projector to pair with this model, or None to run it text-only. `./` means the file sits next to the model; other paths are relative to the Models folder. Applied the next time the model loads.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择与此模型配对的投影器（projector），或选择“无”以纯文本方式运行。“./”表示文件与模型在同一文件夹；其他路径相对于 Models 文件夹。下次加载模型时生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇與此模型配對的投影器（projector），或選擇「無」以純文字方式執行。「./」表示檔案與模型在同一資料夾；其他路徑相對於 Models 資料夾。下次載入模型時生效。"
          }
        }
      }
    },
